{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://identity.memact.org/schemas/zk-sync-response.schema.json",
  "title": "ZKSyncResponse",
  "description": "Schema for synchronization responses between federated context identity providers",
  "type": "object",
  "required": [
    "request_id",
    "status",
    "response_type",
    "timestamp"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "description": "The unique request ID from the corresponding sync request"
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "ERROR",
        "UNAUTHORIZED"
      ],
      "description": "The result status of processing the sync request"
    },
    "error_message": {
      "type": "string",
      "description": "Detailed error string if status is ERROR or UNAUTHORIZED"
    },
    "response_type": {
      "type": "string",
      "enum": [
        "HANDSHAKE_ACK",
        "DELTAS",
        "CLAIM_PROOF"
      ],
      "description": "The payload type contained in the response"
    },
    "timestamp": {
      "type": "integer",
      "description": "Epoch timestamp (seconds) when the sync response was generated"
    },
    "handshake_ack": {
      "type": "object",
      "description": "Handshake parameters. Required if status is SUCCESS and response_type is HANDSHAKE_ACK.",
      "required": [
        "session_id",
        "negotiated_sync_mode"
      ],
      "properties": {
        "session_id": {
          "type": "string",
          "description": "Establish temporary session ID representing the authorized sync relation"
        },
        "negotiated_sync_mode": {
          "type": "string",
          "enum": [
            "PUSH",
            "PULL"
          ],
          "description": "The resolved sync flow direction negotiated by the peers"
        }
      },
      "additionalProperties": false
    },
    "deltas": {
      "type": "object",
      "description": "Incremental delta blocks to catch up. Required if status is SUCCESS and response_type is DELTAS.",
      "required": [
        "blocks",
        "latest_state_root"
      ],
      "properties": {
        "latest_state_root": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$",
          "description": "The final SMT state root after applying all blocks in this delta"
        },
        "blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "block_number",
              "timestamp",
              "old_state_root",
              "new_state_root",
              "batch_proof",
              "transactions_count",
              "validator_signatures"
            ],
            "properties": {
              "block_number": {
                "type": "integer",
                "minimum": 0
              },
              "timestamp": {
                "type": "integer"
              },
              "old_state_root": {
                "type": "string",
                "pattern": "^0x[a-fA-F0-9]{64}$"
              },
              "new_state_root": {
                "type": "string",
                "pattern": "^0x[a-fA-F0-9]{64}$"
              },
              "batch_proof": {
                "type": "object",
                "description": "Serialized ZK rollup proof demonstrating correct multi-state transition batch logic",
                "required": [
                  "proving_scheme",
                  "proof_data"
                ],
                "properties": {
                  "proving_scheme": {
                    "type": "string",
                    "enum": [
                      "groth16",
                      "plonk",
                      "halo2"
                    ],
                    "description": "The cryptographic proving system used"
                  },
                  "proof_data": {
                    "type": "string",
                    "pattern": "^0x[a-fA-F0-9]+$",
                    "description": "The hex-encoded serialized proof payload"
                  }
                },
                "additionalProperties": false
              },
              "transactions_count": {
                "type": "integer",
                "minimum": 1
              },
              "validator_signatures": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "validator_identity",
                    "signature"
                  ],
                  "properties": {
                    "validator_identity": {
                      "type": "string"
                    },
                    "signature": {
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]+$"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "claim_proof": {
      "type": "object",
      "description": "Proof of single leaf context attribute membership. Required if status is SUCCESS and response_type is CLAIM_PROOF.",
      "required": [
        "claim_key",
        "leaf_hash",
        "smt_proof",
        "state_root"
      ],
      "properties": {
        "claim_key": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$",
          "description": "Poseidon hash representing the claim path index inside the SMT"
        },
        "leaf_hash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$",
          "description": "The hash value currently at the leaf location (Poseidon of key, value, and salt)"
        },
        "claim_value": {
          "type": "string",
          "description": "The raw/serialized claim value (only present if authorized for sharing)"
        },
        "salt": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$",
          "description": "The salt value used to construct the leaf hash (only present if authorized for sharing)"
        },
        "smt_proof": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{64}$"
          },
          "description": "An array of sibling node hashes along the SMT path to verify membership"
        },
        "state_root": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$",
          "description": "The SMT context state root against which the proof validates"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
