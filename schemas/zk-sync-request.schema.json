{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://identity.memact.org/schemas/zk-sync-request.schema.json",
  "title": "ZKSyncRequest",
  "description": "Schema for synchronization requests between federated context identity providers",
  "type": "object",
  "required": [
    "request_id",
    "request_type",
    "target_user_identity",
    "timestamp"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "description": "A unique identifier (UUID or cryptographic hash) for tracking this sync transaction"
    },
    "request_type": {
      "type": "string",
      "enum": [
        "HANDSHAKE",
        "PULL_DELTAS",
        "PUSH_DELTAS",
        "PULL_CLAIM"
      ],
      "description": "The type of synchronization operation being performed"
    },
    "target_user_identity": {
      "type": "string",
      "description": "Decentralized identifier (DID) or resource URI of the user context being synced"
    },
    "timestamp": {
      "type": "integer",
      "description": "Epoch timestamp (seconds) when the sync request was sent"
    },
    "handshake_details": {
      "type": "object",
      "description": "Metadata for establishing federated connection trust. Required if request_type is HANDSHAKE.",
      "required": [
        "provider_identity",
        "supported_sync_modes",
        "user_consent_token"
      ],
      "properties": {
        "provider_identity": {
          "type": "string",
          "description": "Public identifier or domain URI of the requesting provider node"
        },
        "supported_sync_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "PUSH",
              "PULL"
            ]
          },
          "description": "The synchronization modes supported by the requesting node"
        },
        "user_consent_token": {
          "type": "string",
          "description": "A base64url-encoded JSON Web Signature (JWS) signed by the user authorizing cross-provider syncing"
        }
      },
      "additionalProperties": false
    },
    "delta_details": {
      "type": "object",
      "description": "Parameters for ledger height synchronization. Required if request_type is PULL_DELTAS or PUSH_DELTAS.",
      "required": [
        "since_block_number",
        "known_state_root"
      ],
      "properties": {
        "since_block_number": {
          "type": "integer",
          "minimum": 0,
          "description": "The starting block height for the delta sync catch-up"
        },
        "known_state_root": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$",
          "description": "Hex encoded 32-byte hash representing the sender's current state root"
        },
        "pushed_block": {
          "type": "object",
          "description": "The latest consensus block payload being pushed (matching ZKConsensusBlock schema)",
          "required": [
            "block_number",
            "timestamp",
            "old_state_root",
            "new_state_root",
            "batch_proof",
            "transactions_count",
            "validator_signatures"
          ],
          "properties": {
            "block_number": {
              "type": "integer",
              "minimum": 0
            },
            "timestamp": {
              "type": "integer"
            },
            "old_state_root": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{64}$"
            },
            "new_state_root": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{64}$"
            },
            "batch_proof": {
              "type": "object",
              "description": "Serialized ZK rollup proof demonstrating correct multi-state transition batch logic",
              "required": [
                "proving_scheme",
                "proof_data"
              ],
              "properties": {
                "proving_scheme": {
                  "type": "string",
                  "enum": [
                    "groth16",
                    "plonk",
                    "halo2"
                  ],
                  "description": "The cryptographic proving system used"
                },
                "proof_data": {
                  "type": "string",
                  "pattern": "^0x[a-fA-F0-9]+$",
                  "description": "The hex-encoded serialized proof payload"
                }
              },
              "additionalProperties": false
            },
            "transactions_count": {
              "type": "integer",
              "minimum": 1
            },
            "validator_signatures": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "validator_identity",
                  "signature"
                ],
                "properties": {
                  "validator_identity": {
                    "type": "string"
                  },
                  "signature": {
                    "type": "string",
                    "pattern": "^0x[a-fA-F0-9]+$"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "claim_details": {
      "type": "object",
      "description": "Parameters for querying individual claim status. Required if request_type is PULL_CLAIM.",
      "required": [
        "claim_key"
      ],
      "properties": {
        "claim_key": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$",
          "description": "Poseidon hash representing the claim path index to resolve"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
