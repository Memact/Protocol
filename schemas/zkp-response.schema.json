{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://identity.memact.org/schemas/zkp-response.schema.json",
  "title": "ZKPResponseAssertion",
  "description": "Schema for the cap_zkp_assertion claim returned in the OAuth token payload",
  "type": "object",
  "required": [
    "circuit_id",
    "verification_key_uri",
    "public_inputs",
    "proof"
  ],
  "properties": {
    "circuit_id": {
      "type": "string",
      "description": "Identifier of the ZK circuit verifying this proof"
    },
    "verification_key_uri": {
      "type": "string",
      "format": "uri",
      "description": "URI to retrieve the public verification key (vkey.json) for this proof circuit"
    },
    "public_inputs": {
      "type": "object",
      "description": "The public parameters that were input into the circuit",
      "required": [
        "attribute_hash",
        "operator",
        "value",
        "nonce"
      ],
      "properties": {
        "attribute_hash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]+$",
          "description": "Hex encoded salt-hashed attribute identifier, e.g., Keccak256 or SHA256"
        },
        "operator": {
          "type": "string",
          "enum": [
            "EQ",
            "NEQ",
            "GT",
            "GTE",
            "LT",
            "LTE",
            "IN",
            "NOT_IN"
          ]
        },
        "value": {
          "type": [
            "string",
            "number",
            "boolean",
            "array"
          ],
          "description": "The public condition target value verified by the circuit"
        },
        "nonce": {
          "type": "string",
          "description": "The original random nonce provided by the client"
        }
      },
      "additionalProperties": false
    },
    "proof": {
      "type": "object",
      "description": "The cryptographic proof payload",
      "required": [
        "proving_scheme",
        "proof_data"
      ],
      "properties": {
        "proving_scheme": {
          "type": "string",
          "enum": [
            "groth16",
            "plonk",
            "halo2"
          ],
          "description": "The ZK proving system used to generate the proof"
        },
        "proof_data": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]+$",
          "description": "The hex-encoded serialized proof string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
